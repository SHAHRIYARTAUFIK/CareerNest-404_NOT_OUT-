{
  "version": 2,
  "builds": [
    { "src": "main.py", "use": "@vercel/python" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/docs(.*)", "dest": "main.py" },
    { "src": "/openapi.json", "dest": "main.py" },
    { "src": "/companies(.*)", "dest": "main.py" },
    { "src": "/jobs(.*)", "dest": "main.py" },
    { "src": "/applications(.*)", "dest": "main.py" },
    { "src": "/students(.*)", "dest": "main.py" },
    { "src": "/bookmarks(.*)", "dest": "main.py" },
    { "src": "/stats(.*)", "dest": "main.py" }
  ]
}
